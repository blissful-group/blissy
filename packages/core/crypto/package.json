{
  "name": "@blissy-auth/crypto",
  "version": "0.0.2",
  "description": "Shared Effect crypto service for Blissy auth packages.",
  "license": "MIT",
  "author": "Marco van Harten <marcovanharten89@gmail.com> (https://github.com/blissful89)",
  "homepage": "https://github.com/blissful-group/blissy#readme",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.mts",
          "default": "./dist/index.mjs"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "format": "eslint . --fix",
    "lint": "npm-run-all --parallel lint:eslint lint:tsc --parallel lint:dependencies",
    "lint:dependencies": "pnpx depcheck",
    "lint:eslint": "eslint .",
    "lint:tsc": "tsc",
    "release": "pnpm publish",
    "prepack": "pnpm build",
    "test": "vitest run"
  },
  "dependencies": {
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "@blissy-auth/eslint-config": "workspace:^",
    "@blissy-auth/typescript-config": "workspace:^",
    "@vitest/coverage-v8": "^4.1.7",
    "npm-run-all2": "^9.0.0",
    "eslint": "*",
    "typescript": "*",
    "tsdown": "^0.22.0",
    "vitest": "^4.1.7"
  }
}
