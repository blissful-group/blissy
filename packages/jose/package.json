{
  "name": "@blissy-auth/jose",
  "version": "0.0.1",
  "description": "TypeScript implementation of the JOSE (Javascript Object Signing and Encryption) specifications with support for JWT, JWS, JWE, JWK, JWKS, and JWA, providing standards-compliant signing, verification, encryption, decryption, and key management.",
  "license": "MIT",
  "author": "Marco van Harten <marcovanharten89@gmail.com> (https://github.com/blissful89)",
  "homepage": "https://github.com/blissful-group/blissy#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "source": "./index.ts",
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blissful-group/blissy.git"
  },
  "bugs": {
    "url": "https://github.com/blissful-group/blissy/issues"
  },
  "scripts": {
    "build": "tsdown",
    "format": "eslint . --fix",
    "lint": "npm-run-all --parallel lint:eslint lint:tsc --parallel lint:dependencies",
    "lint:dependencies": "pnpx depcheck",
    "lint:eslint": "eslint .",
    "lint:tsc": "tsc",
    "publish": "npm publish",
    "release": "run-s build publish",
    "test": "run-p test:unit test:bench",
    "test:unit": "vitest run",
    "test:bench": "vitest bench --run"
  },
  "dependencies": {
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "@blissy-auth/eslint-config": "workspace:^",
    "@blissy-auth/typescript-config": "workspace:^",
    "@vitest/coverage-v8": "^4.1.7",
    "npm-run-all2": "9.0.0",
    "eslint": "*",
    "typescript": "*",
    "tsdown": "^0.22.0",
    "vitest": "^4.1.7"
  }
}
