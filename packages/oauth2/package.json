{
  "name": "@blissy-auth/oauth2",
  "version": "0.0.1",
  "description": "TypeScript implementation of the OAuth 2.0 protocol primitives with support for authorization requests, token requests, PKCE, scopes, client authentication, token revocation, and token introspection.",
  "license": "MIT",
  "author": "Marco van Harten <marcovanharten89@gmail.com> (https://github.com/blissful89)",
  "homepage": "https://github.com/blissful-group/blissy#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./source": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blissful-group/blissy.git"
  },
  "bugs": {
    "url": "https://github.com/blissful-group/blissy/issues"
  },
  "keywords": [
    "oauth",
    "oauth2",
    "authorization",
    "authentication",
    "pkce",
    "scope",
    "token",
    "revocation",
    "introspection",
    "effect"
  ],
  "scripts": {
    "build": "tsdown",
    "format": "eslint . --fix",
    "lint": "npm-run-all --parallel lint:eslint lint:tsc --parallel lint:dependencies",
    "lint:dependencies": "pnpx depcheck",
    "lint:eslint": "eslint .",
    "lint:tsc": "tsc",
    "release": "run-s build && npm publish",
    "test": "vitest run"
  },
  "dependencies": {
    "@blissy-auth/crypto": "workspace:^",
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "@blissy-auth/eslint-config": "workspace:^",
    "@blissy-auth/typescript-config": "workspace:^",
    "@vitest/coverage-v8": "^4.1.7",
    "npm-run-all2": "^9.0.0",
    "eslint": "*",
    "typescript": "*",
    "tsdown": "^0.22.0",
    "vitest": "^4.1.7"
  }
}
